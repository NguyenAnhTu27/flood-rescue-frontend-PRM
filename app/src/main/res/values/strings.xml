    <string name="public_terms_title">Điều khoản sử dụng</string>
    <string name="public_terms_subtitle">Cập nhật lần cuối: 24/05/2024</string>
    <string name="public_terms_section_1_title">1. Mục đích sử dụng</string>
    <string name="public_terms_section_1_body">Ứng dụng được thiết kế để hỗ trợ người dân gửi yêu cầu cứu hộ, nhận thông tin khẩn cấp và kết nối với lực lượng điều phối trong các tình huống thiên tai.</string>
    <string name="public_terms_section_2_title">2. Tính xác thực yêu cầu</string>
    <string name="public_terms_section_2_body">Người dùng cần cung cấp thông tin trung thực, vị trí rõ ràng và mô tả chính xác để hệ thống ưu tiên xử lý đúng mức độ khẩn cấp.</string>
    <string name="public_terms_section_3_title">3. Bảo mật và quyền riêng tư</string>
    <string name="public_terms_section_3_body">Chúng tôi thu thập dữ liệu cần thiết để xác minh, điều phối và phản hồi cứu hộ. Dữ liệu được quản lý theo quy định hiện hành và chỉ dùng cho mục đích nghiệp vụ.</string>
    <string name="public_terms_section_4_title">4. Thay đổi điều khoản</string>
    <string name="public_terms_section_4_body">Ban quản trị có thể cập nhật điều khoản để phù hợp với vận hành thực tế. Mọi thay đổi quan trọng sẽ được thông báo công khai trong ứng dụng.</string>
    <string name="public_terms_note">Lưu ý: Việc tiếp tục sử dụng ứng dụng đồng nghĩa với việc bạn hiểu và đồng ý với các quy định vận hành trong từng giai đoạn cứu trợ.</string>
    <string name="public_terms_accept">Tôi đã hiểu và đồng ý</string>
    <string name="public_terms_back_register">Quay lại màn hình đăng ký</string>
    <string name="public_privacy_title">Chính sách bảo mật</string>
    <string name="public_privacy_hero">Quyền riêng tư của bạn\nlà ưu tiên hàng đầu</string>
    <string name="public_privacy_intro">Ứng dụng cứu trợ lũ lụt cam kết bảo vệ dữ liệu cá nhân của bạn. Chính sách này giải thích cách chúng tôi xử lý thông tin để đảm bảo an toàn và hiệu quả cứu nạn.</string>
    <string name="public_privacy_section_1_title">1. Thu thập dữ liệu</string>
    <string name="public_privacy_section_1_body">Chúng tôi thu thập thông tin tối thiểu như tên, số điện thoại liên lạc và tình trạng khẩn cấp bạn cung cấp khi gửi yêu cầu cứu hộ.</string>
    <string name="public_privacy_section_2_title">2. Sử dụng thông tin</string>
    <string name="public_privacy_section_2_body">Thông tin được dùng để xác minh yêu cầu, điều phối lực lượng cứu nạn và đảm bảo phản hồi nhanh trong thời gian thiên tai.</string>
    <string name="public_privacy_section_3_title">3. Bảo mật dữ liệu</string>
    <string name="public_privacy_section_3_body">Toàn bộ dữ liệu truyền tải giữa thiết bị và máy chủ được bảo vệ theo tiêu chuẩn kỹ thuật hiện hành, giới hạn truy cập theo vai trò nghiệp vụ.</string>
    <string name="public_privacy_section_4_title">4. Lưu trữ và xóa bỏ</string>
    <string name="public_privacy_section_4_body">Dữ liệu được lưu trữ trong thời gian cần thiết cho vận hành cứu hộ và được xóa hoặc ẩn danh khi không còn mục đích sử dụng hợp pháp.</string>
    <string name="public_privacy_badge_title">Tiêu chuẩn quốc tế</string>
    <string name="public_privacy_badge_body">Tuân thủ nghiêm ngặt các quy định về bảo vệ dữ liệu cá nhân trong nghiệp vụ công.</string>
