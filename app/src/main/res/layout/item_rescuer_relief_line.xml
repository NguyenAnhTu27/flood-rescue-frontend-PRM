<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_surface_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <TextView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_chip_success"
        android:gravity="center"
        android:text="H"
        android:textColor="@color/login_teal"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textRescuerReliefItemName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nước sạch"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textRescuerReliefItemCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="DM - V1 Thùng"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/textRescuerReliefItemQty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="x10 thùng"
        android:textColor="@color/accent_dark"
        android:textSize="13sp"
        android:textStyle="bold" />

</LinearLayout>
