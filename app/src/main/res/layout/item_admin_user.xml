<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="22dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/stroke_soft"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textAdminUserInitial"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_circle_soft"
                android:gravity="center"
                android:textColor="@color/accent"
                android:textStyle="bold"
                tools:text="NA" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textAdminUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="Nguyễn An" />

                <TextView
                    android:id="@+id/textAdminUserEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    tools:text="nguyen.an@email.com" />
            </LinearLayout>

            <TextView
                android:id="@+id/textAdminUserStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_success"
                android:paddingStart="10dp"
                android:paddingTop="5dp"
                android:paddingEnd="10dp"
                android:paddingBottom="5dp"
                android:textColor="@color/success"
                android:textSize="10sp"
                android:textStyle="bold"
                tools:text="HOẠT ĐỘNG" />
        </LinearLayout>

        <TextView
            android:id="@+id/textAdminUserPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            tools:text="0901 234 567" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textAdminUserRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_info"
                android:paddingStart="10dp"
                android:paddingTop="5dp"
                android:paddingEnd="10dp"
                android:paddingBottom="5dp"
                android:textColor="@color/accent_dark"
                android:textSize="10sp"
                android:textStyle="bold"
                tools:text="ADMIN" />

            <TextView
                android:id="@+id/textAdminUserCreated"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:gravity="end"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                tools:text="24/03/2025" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/buttonAdminUserEdit"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/bg_admin_filter_inactive"
                android:gravity="center"
                android:text="@string/admin_users_action_edit"
                android:textColor="@color/text_secondary"
                android:textStyle="bold" />

            <Space android:layout_width="8dp" android:layout_height="match_parent" />

            <TextView
                android:id="@+id/buttonAdminUserToggleStatus"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_success_outline"
                android:gravity="center"
                android:text="@string/admin_users_action_lock"
                android:textColor="@color/success"
                android:textStyle="bold"
                tools:text="Khóa" />

            <Space android:layout_width="8dp" android:layout_height="match_parent" />

            <TextView
                android:id="@+id/buttonAdminUserReset"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip_info"
                android:gravity="center"
                android:text="@string/admin_users_action_reset"
                android:textColor="@color/accent_dark"
                android:textStyle="bold" />

            <Space android:layout_width="8dp" android:layout_height="match_parent" />

            <TextView
                android:id="@+id/buttonAdminUserDelete"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_button_danger_outline"
                android:gravity="center"
                android:text="!"
                android:textColor="@color/danger"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
