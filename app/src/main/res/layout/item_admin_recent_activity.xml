<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/textAdminActivityBadge"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/bg_circle_soft"
        android:gravity="center"
        android:text="LG"
        android:textColor="@color/accent"
        android:textStyle="bold"
        tools:text="LG" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textAdminActivityTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="RESET_PASSWORD" />

        <TextView
            android:id="@+id/textAdminActivityDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            tools:text="Cập nhật thành công bởi Admin" />
    </LinearLayout>

    <TextView
        android:id="@+id/textAdminActivityTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        tools:text="12:45" />
</LinearLayout>
