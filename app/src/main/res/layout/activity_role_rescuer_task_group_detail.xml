<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="3dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp">

        <ImageView
            android:id="@+id/buttonBackRescuerTaskGroupDetail"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_arrow_left"
            android:tint="@color/text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:text="@string/rescuer_task_group_detail_title"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/buttonRefreshRescuerTaskGroupDetail"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_refresh"
            android:tint="@color/accent_dark" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressRescuerTaskGroupDetail"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:visibility="gone" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/textRescuerTaskGroupDetailError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_citizen_dashboard_alert"
                android:padding="14dp"
                android:textColor="@color/danger"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_surface_card"
                android:elevation="1dp"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textRescuerTaskGroupCode"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="#TG-1234"
                        android:textColor="@color/accent_dark"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textRescuerTaskGroupStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip_warning"
                        android:paddingStart="10dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="5dp"
                        android:text="ĐANG THỰC HIỆN"
                        android:textColor="@color/warning"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/textRescuerTaskGroupTeam"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Đội Cứu Hộ Số 1"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textRescuerTaskGroupMeta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    tools:text="Tạo bởi Nguyễn Văn A&#10;Cập nhật 27/10/2023 14:15" />

                <TextView
                    android:id="@+id/textRescuerTaskGroupNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_rescuer_detail_highlight"
                    android:padding="14dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    tools:text="Phối hợp ứng cứu tại khu vực ngập lụt sâu, ưu tiên hộ có trẻ em và người già." />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/buttonRescuerGroupTabRequests"
                        style="@style/CoordinatorQueueFilterChip"
                        android:background="@drawable/bg_rescuer_tab_active"
                        android:text="@string/rescuer_task_group_detail_tab_requests"
                        android:textColor="@color/accent_dark" />

                    <TextView
                        android:id="@+id/buttonRescuerGroupTabAssignments"
                        style="@style/CoordinatorQueueFilterChip"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_rescuer_tab_inactive"
                        android:text="@string/rescuer_task_group_detail_tab_assignments" />

                    <TextView
                        android:id="@+id/buttonRescuerGroupTabTimeline"
                        style="@style/CoordinatorQueueFilterChip"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_rescuer_tab_inactive"
                        android:text="@string/rescuer_task_group_detail_tab_timeline" />

                    <TextView
                        android:id="@+id/buttonRescuerGroupTabAcks"
                        style="@style/CoordinatorQueueFilterChip"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_rescuer_tab_inactive"
                        android:text="@string/rescuer_task_group_detail_tab_acks" />
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/textRescuerTaskGroupSectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/rescuer_task_group_detail_section_requests"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/sectionRescuerGroupRequests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerRescuerGroupRequests"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:itemCount="2"
                    tools:listitem="@layout/item_rescuer_group_request" />

                <TextView
                    android:id="@+id/textRescuerGroupRequestsEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_surface_card"
                    android:gravity="center"
                    android:padding="16dp"
                    android:text="@string/rescuer_task_group_detail_empty_requests"
                    android:textColor="@color/text_secondary"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/sectionRescuerGroupAssignments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerRescuerGroupAssignments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:itemCount="2"
                    tools:listitem="@layout/item_rescuer_group_assignment" />

                <TextView
                    android:id="@+id/textRescuerGroupAssignmentsEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_surface_card"
                    android:gravity="center"
                    android:padding="16dp"
                    android:text="@string/rescuer_task_group_detail_empty_assignments"
                    android:textColor="@color/text_secondary"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/sectionRescuerGroupTimeline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerRescuerGroupTimeline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:itemCount="3"
                    tools:listitem="@layout/item_rescuer_group_timeline" />

                <TextView
                    android:id="@+id/textRescuerGroupTimelineEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_surface_card"
                    android:gravity="center"
                    android:padding="16dp"
                    android:text="@string/rescuer_task_group_detail_empty_timeline"
                    android:textColor="@color/text_secondary"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/sectionRescuerGroupAcks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerRescuerGroupEmergency"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:itemCount="2"
                    tools:listitem="@layout/item_rescuer_group_emergency" />

                <TextView
                    android:id="@+id/textRescuerGroupAcksEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_surface_card"
                    android:gravity="center"
                    android:padding="16dp"
                    android:text="@string/rescuer_task_group_detail_empty_acks"
                    android:textColor="@color/text_secondary"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="84dp"
        android:background="@drawable/bg_coordinator_bottom_panel"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/buttonRescuerGroupEmergency"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_cta_secondary"
            android:gravity="center"
            android:text="@string/rescuer_task_group_detail_emergency_action"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <Space
            android:layout_width="12dp"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/buttonRescuerGroupStatus"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_queue_action_button"
            android:gravity="center"
            android:text="@string/rescuer_task_group_detail_status_action"
            android:textColor="@color/white"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
