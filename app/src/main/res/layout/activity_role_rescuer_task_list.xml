<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:elevation="3dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp">

            <ImageView
                android:id="@+id/buttonBackRescuerTasks"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_arrow_left"
                android:tint="@color/text_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:text="@string/rescuer_task_list_title"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/buttonRefreshRescuerTasks"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_refresh" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_queue_search"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_search"
                        android:tint="@color/text_muted" />

                    <EditText
                        android:id="@+id/editRescuerTaskSearch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@null"
                        android:hint="@string/rescuer_task_list_search_hint"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:maxLines="1"
                        android:padding="0dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_muted"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/buttonRescuerTaskSearch"
                    android:layout_width="56dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_queue_filter_button"
                    android:gravity="center"
                    android:text="@string/rescuer_task_list_search_action"
                    android:textColor="@color/accent_dark"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/buttonRescuerFilterAll"
                        style="@style/CoordinatorQueueFilterChip"
                        android:text="@string/rescuer_task_list_filter_all" />

                    <TextView
                        android:id="@+id/buttonRescuerFilterProgress"
                        style="@style/CoordinatorQueueFilterChip"
                        android:layout_marginStart="8dp"
                        android:text="@string/rescuer_task_list_filter_progress" />

                    <TextView
                        android:id="@+id/buttonRescuerFilterPending"
                        style="@style/CoordinatorQueueFilterChip"
                        android:layout_marginStart="8dp"
                        android:text="@string/rescuer_task_list_filter_pending" />

                    <TextView
                        android:id="@+id/buttonRescuerFilterDone"
                        style="@style/CoordinatorQueueFilterChip"
                        android:layout_marginStart="8dp"
                        android:text="@string/rescuer_task_list_filter_done" />
                </LinearLayout>
            </HorizontalScrollView>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/buttonRescuerQuickHigh"
                        style="@style/CoordinatorQueueFilterChip"
                        android:background="@drawable/bg_chip_danger"
                        android:text="@string/rescuer_task_list_quick_high"
                        android:textColor="@color/danger" />

                    <TextView
                        android:id="@+id/buttonRescuerQuickEmergency"
                        style="@style/CoordinatorQueueFilterChip"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_chip_warning"
                        android:text="@string/rescuer_task_list_quick_emergency"
                        android:textColor="@color/warning" />

                    <TextView
                        android:id="@+id/buttonRescuerQuickVerify"
                        style="@style/CoordinatorQueueFilterChip"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_chip_info"
                        android:text="@string/rescuer_task_list_quick_verify"
                        android:textColor="@color/accent_dark" />
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/textRescuerTaskCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/rescuer_task_list_count_default"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerRescuerTasks"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="92dp"
                tools:listitem="@layout/item_rescuer_task" />

            <TextView
                android:id="@+id/textRescuerTasksError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_citizen_dashboard_alert"
                android:padding="14dp"
                android:textColor="@color/danger"
                android:visibility="gone" />

            <TextView
                android:id="@+id/textRescuerTasksEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:padding="28dp"
                android:text="@string/rescuer_task_list_empty"
                android:textColor="@color/text_secondary"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/progressRescuerTasks"
                style="?android:attr/progressBarStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:background="@drawable/bg_coordinator_bottom_panel"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <LinearLayout
                android:id="@+id/navRescuerTasksOverview"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_nav_home"
                    android:tint="@color/nav_inactive" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/coordinator_nav_overview"
                    android:textColor="@color/nav_inactive"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navRescuerTasksCurrent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_nav_list"
                    android:tint="@color/accent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/rescuer_task_list_bottom_tasks"
                    android:textColor="@color/accent"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navRescuerTasksNotifications"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_nav_notification"
                    android:tint="@color/nav_inactive" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/citizen_dashboard_nav_notifications"
                    android:textColor="@color/nav_inactive"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navRescuerTasksProfile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_nav_profile"
                    android:tint="@color/nav_inactive" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/citizen_dashboard_nav_profile"
                    android:textColor="@color/nav_inactive"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/buttonRescuerTaskGroupFab"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="88dp"
        android:background="@drawable/bg_fab_primary"
        android:elevation="6dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_nav_add"
            android:tint="@color/white" />
    </FrameLayout>

</FrameLayout>
