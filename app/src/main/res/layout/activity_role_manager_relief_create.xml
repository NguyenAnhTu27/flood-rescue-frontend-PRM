<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_bg"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/buttonManagerCreateBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_media_previous" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="Tạo yêu cầu cứu trợ"
                    android:textColor="@color/text_primary"
                    android:textSize="21sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/stroke_soft"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Liên kết cứu hộ"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/textManagerGeneratedCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Mã đang tạo..."
                        android:textColor="@color/accent_dark"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <EditText
                android:id="@+id/inputManagerRescueLink"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_manager_search"
                android:hint="Mã yêu cầu cứu hộ (không bắt buộc)"
                android:inputType="number"
                android:minHeight="52dp"
                android:paddingHorizontal="16dp" />

            <EditText
                android:id="@+id/inputManagerTargetArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_manager_search"
                android:hint="Khu vực mục tiêu"
                android:minHeight="52dp"
                android:paddingHorizontal="16dp" />

            <EditText
                android:id="@+id/inputManagerAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_manager_search"
                android:hint="Địa chỉ ảnh hưởng"
                android:minHeight="52dp"
                android:paddingHorizontal="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/inputManagerLatitude"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_manager_search"
                    android:hint="Kinh độ"
                    android:inputType="numberDecimal|numberSigned"
                    android:minHeight="52dp"
                    android:paddingHorizontal="16dp" />

                <EditText
                    android:id="@+id/inputManagerLongitude"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_manager_search"
                    android:hint="Vĩ độ"
                    android:inputType="numberDecimal|numberSigned"
                    android:minHeight="52dp"
                    android:paddingHorizontal="16dp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_manager_map_preview" />

            <EditText
                android:id="@+id/inputManagerLocationDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_manager_search"
                android:hint="Mô tả vị trí cứu trợ"
                android:minHeight="52dp"
                android:paddingHorizontal="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Danh sách hàng cứu trợ"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/buttonManagerAddLine"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thêm hàng"
                    android:textColor="@color/accent_dark"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/textManagerCreateLineHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Tải danh mục vật tư..."
                android:textColor="@color/text_secondary" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerManagerCreateLines"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:nestedScrollingEnabled="false" />

            <EditText
                android:id="@+id/inputManagerCreateNote"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_manager_search"
                android:gravity="top"
                android:hint="Ghi chú nội bộ / mô tả nhu cầu chi tiết"
                android:padding="16dp" />

            <ProgressBar
                android:id="@+id/progressManagerCreate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/textManagerCreateError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:textColor="@color/danger"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonManagerSubmitCreate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Tạo yêu cầu cứu trợ"
                app:backgroundTint="@color/primary" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
