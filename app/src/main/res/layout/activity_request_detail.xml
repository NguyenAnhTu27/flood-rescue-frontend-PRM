<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal"><TextView android:id="@+id/buttonBack" android:layout_width="40dp" android:layout_height="40dp" android:gravity="center" android:text="←" android:textColor="@color/text_primary" android:textSize="20sp" android:textStyle="bold" /><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Chi tiết yêu cầu" android:textColor="@color/text_primary" android:textStyle="bold" /><TextView android:id="@+id/buttonMenu" android:layout_width="40dp" android:layout_height="40dp" android:gravity="center" android:text="⋮" android:textColor="@color/text_primary" android:textSize="18sp" /></LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:gravity="center_vertical" android:orientation="horizontal"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="#REQ-12345" android:textColor="@color/text_primary" android:textSize="28sp" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_chip_info" android:paddingHorizontal="10dp" android:paddingVertical="5dp" android:text="Cứu hộ" android:textColor="@color/accent" android:textSize="12sp" android:textStyle="bold" /></LinearLayout>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Gửi lúc 09:45 • 24/10/2023" android:textColor="@color/text_secondary" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:background="@drawable/bg_alert_card" android:gravity="center_vertical" android:orientation="horizontal" android:padding="14dp"><TextView android:layout_width="28dp" android:layout_height="28dp" android:gravity="center" android:text="▲" android:textColor="@color/danger" /><LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:layout_weight="1" android:orientation="vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mức độ: Khẩn cấp" android:textColor="@color/danger" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Nước đang dâng cao, cần hỗ trợ ngay lập tức." android:textColor="#B42318" android:textSize="12sp" /></LinearLayout></LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:background="@drawable/bg_input_soft" android:orientation="vertical" android:padding="14dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ĐỊA CHỈ" android:textColor="@color/text_muted" android:textSize="11sp" android:textStyle="bold" /><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="123 Đường Bờ Sông, Phường 5, TP. Huế, Thừa Thiên Huế" android:textColor="@color/text_primary" android:textStyle="bold" /><LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:orientation="horizontal"><LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SỐ NGƯỜI" android:textColor="@color/text_muted" android:textSize="11sp" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="04 người (1 người già)" android:textColor="@color/text_primary" /></LinearLayout><LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NỘI DUNG" android:textColor="@color/text_muted" android:textSize="11sp" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Cần xuồng đi tản" android:textColor="@color/text_primary" /></LinearLayout></LinearLayout></LinearLayout>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:text="Tiến độ xử lý" android:textColor="@color/text_primary" android:textStyle="bold" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/bg_input_soft" android:orientation="vertical" android:padding="14dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal"><TextView android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_chip_info" android:gravity="center" android:text="✓" android:textColor="@color/accent" /><LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:layout_weight="1" android:orientation="vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PENDING (Đang chờ)" android:textColor="@color/accent" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10:00, 24/10/2023" android:textColor="@color/text_muted" android:textSize="11sp" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:text="Yêu cầu đã được gửi lên hệ thống." android:textColor="@color/text_primary" /></LinearLayout></LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:orientation="horizontal"><TextView android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_chip_info" android:gravity="center" android:text="✓" android:textColor="@color/accent" /><LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:layout_weight="1" android:orientation="vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="VERIFIED (Đã xác minh)" android:textColor="@color/accent" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10:15, 24/10/2023" android:textColor="@color/text_muted" android:textSize="11sp" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:text="Tổng đài viên đã xác nhận thông tin." android:textColor="@color/text_primary" /></LinearLayout></LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:orientation="horizontal"><TextView android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_chip_info" android:gravity="center" android:text="✓" android:textColor="@color/accent" /><LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:layout_weight="1" android:orientation="vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ASSIGNED (Đã phân công)" android:textColor="@color/accent" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10:30, 24/10/2023" android:textColor="@color/text_muted" android:textSize="11sp" /><LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_surface_card" android:gravity="center_vertical" android:orientation="horizontal" android:padding="10dp"><TextView android:layout_width="34dp" android:layout_height="34dp" android:background="@drawable/bg_photo_placeholder" android:gravity="center" android:text="07" android:textColor="@color/white" /><LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:layout_weight="1" android:orientation="vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Đội Cứu Hộ 07" android:textColor="@color/text_primary" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cách 1.2 km" android:textColor="@color/text_secondary" android:textSize="12sp" /></LinearLayout><TextView android:layout_width="30dp" android:layout_height="30dp" android:background="@drawable/bg_circle_soft" android:gravity="center" android:text="✆" android:textColor="@color/accent" /></LinearLayout></LinearLayout></LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:orientation="horizontal"><TextView android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_chip_info" android:gravity="center" android:text="✓" android:textColor="@color/accent" /><LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:layout_weight="1" android:orientation="vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="IN_PROGRESS (Đang xử lý)" android:textColor="@color/accent" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hiện tại" android:textColor="@color/text_muted" android:textSize="11sp" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:text="Đội cứu hộ đang trên đường tới vị trí của bạn." android:textColor="@color/text_primary" /></LinearLayout></LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:orientation="horizontal"><TextView android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_chip_soft" android:gravity="center" android:text="•" android:textColor="@color/text_muted" /><LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:layout_weight="1" android:orientation="vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="COMPLETED (Hoàn tất)" android:textColor="@color/text_muted" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dự kiến" android:textColor="@color/text_muted" android:textSize="11sp" /></LinearLayout></LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout android:layout_width="match_parent" android:layout_height="88dp" android:background="@color/white" android:elevation="12dp" android:gravity="center" android:orientation="horizontal" android:padding="16dp"><Button android:id="@+id/buttonOpenUpdate" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:background="@drawable/bg_cta_secondary" android:text="Hủy yêu cầu" android:textAllCaps="false" android:textColor="@color/text_primary" /><Button android:id="@+id/buttonOpenChat" android:layout_width="0dp" android:layout_height="48dp" android:layout_marginStart="10dp" android:layout_weight="1" android:background="@drawable/bg_cta_primary" android:text="Chat điều phối" android:textAllCaps="false" android:textColor="@color/white" /></LinearLayout>
</LinearLayout>