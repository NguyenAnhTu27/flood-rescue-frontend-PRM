<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp"
        android:paddingTop="18dp"
        android:paddingBottom="12dp">

        <FrameLayout
            android:id="@+id/buttonBackTaskGroupList"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_surface_card">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_back"
                android:tint="@color/text_primary" />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="@string/coordinator_task_group_list_title"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressTaskGroupList"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/textTaskGroupListError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_citizen_dashboard_alert"
            android:padding="14dp"
            android:textColor="@color/danger"
            android:visibility="gone" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/buttonTaskGroupFilterAll"
                    style="@style/CoordinatorQueueFilterChip"
                    android:text="@string/coordinator_task_group_list_filter_all" />

                <TextView
                    android:id="@+id/buttonTaskGroupFilterWaiting"
                    style="@style/CoordinatorQueueFilterChip"
                    android:layout_marginStart="8dp"
                    android:text="@string/coordinator_task_group_list_filter_waiting" />

                <TextView
                    android:id="@+id/buttonTaskGroupFilterActive"
                    style="@style/CoordinatorQueueFilterChip"
                    android:layout_marginStart="8dp"
                    android:text="@string/coordinator_task_group_list_filter_active" />

                <TextView
                    android:id="@+id/buttonTaskGroupFilterDone"
                    style="@style/CoordinatorQueueFilterChip"
                    android:layout_marginStart="8dp"
                    android:text="@string/coordinator_task_group_list_filter_done" />
            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/buttonTaskGroupCreateNew"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_cta_primary"
            android:gravity="center"
            android:text="@string/coordinator_task_group_list_create"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerTaskGroupList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:layout_weight="1"
            tools:itemCount="3"
            tools:listitem="@layout/item_coordinator_task_group_list" />

        <TextView
            android:id="@+id/textTaskGroupListEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="16dp"
            android:text="@string/coordinator_task_group_list_empty"
            android:textColor="@color/text_secondary"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/white"
        android:elevation="8dp"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/navTaskGroupOverview"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_nav_home"
                android:tint="@color/nav_inactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/coordinator_nav_overview"
                android:textColor="@color/nav_inactive"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navTaskGroupQueue"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_nav_list"
                android:tint="@color/nav_inactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/coordinator_nav_queue"
                android:textColor="@color/nav_inactive"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navTaskGroupMap"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_queue_map"
                android:tint="@color/nav_inactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/coordinator_nav_map"
                android:textColor="@color/nav_inactive"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navTaskGroupTeam"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_queue_team"
                android:tint="@color/accent_dark" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/coordinator_nav_team"
                android:textColor="@color/accent_dark"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navTaskGroupSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_queue_settings"
                android:tint="@color/nav_inactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/coordinator_nav_settings"
                android:textColor="@color/nav_inactive"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
